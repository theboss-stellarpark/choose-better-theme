{% liquid
  assign type_groups = "T-SHIRT,HOODIE,ACCESSORIES" | split: ","
  assign type_labels  = "T-Shirts,Hoodies,Accessories" | split: ","
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<div
  class="collection-grouped section section--page-width color-{{ section.settings.color_scheme }} spacing-style"
  style="--padding-block-start: {{ section.settings['padding-block-start'] }}px; --padding-block-end: {{ section.settings['padding-block-end'] }}px;"
>
  {% for type_name in type_groups %}
    {% assign type_products = collection.products | where: "type", type_name %}
    {% if type_products.size > 0 %}
      <div class="collection-grouped__group">
        <h2 class="collection-grouped__heading">{{ type_labels[forloop.index0] }}</h2>
        <ul class="collection-grouped__grid" role="list">
          {% for product in type_products %}
            <li class="collection-grouped__item">
              {% # theme-check-disable %}
              {% content_for 'block', type: '_product-card', id: 'product-card', closest.product: product %}
              {% # theme-check-enable %}
            </li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}
  {% endfor %}
</div>

{% stylesheet %}
  .collection-grouped__group {
    margin-block-end: 48px;
  }

  .collection-grouped__group:last-child {
    margin-block-end: 0;
  }

  .collection-grouped__heading {
    font-family: var(--font-heading--family);
    padding-block-end: 16px;
    margin-block-end: 24px;
    border-bottom: 1px solid var(--color-border);
  }

  .collection-grouped__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(480px, 100%), 1fr));
    gap: 24px 16px;
    list-style: none;
    padding: 0;
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Products by Type",
  "templates": ["collection"],
  "blocks": [
    {
      "type": "_product-card"
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 96,
      "step": 8,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 96,
      "step": 8,
      "unit": "px",
      "default": 48
    }
  ]
}
{% endschema %}
