{% comment %}
  Renders a size chart table based on a product tag matching "size-chart:[key]".
  Usage: {% render 'size-chart', product: product %}
  To add a new chart: add a {% when '[key]' %} block and tag products "size-chart:[key]".
{% endcomment %}

{% assign size_chart_key = '' %}
{% for tag in product.tags %}
  {% if tag contains 'size-chart:' %}
    {% assign size_chart_key = tag | remove: 'size-chart:' %}
    {% break %}
  {% endif %}
{% endfor %}

{% if size_chart_key != blank %}
  <div class="size-chart">
    {% case size_chart_key %}

      {% when 'premium-hoodie' %}
        <table class="size-chart__table">
          <thead>
            <tr>
              <th></th>
              <th>LENGTH (in)</th>
              <th>WIDTH (in)</th>
              <th>SLEEVE LENGTH (in)</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>S</td><td>28</td><td>20</td><td>34 ½</td></tr>
            <tr><td>M</td><td>29</td><td>22</td><td>35 ½</td></tr>
            <tr><td>L</td><td>30</td><td>24</td><td>36 ½</td></tr>
            <tr><td>XL</td><td>31</td><td>26</td><td>37 ½</td></tr>
            <tr><td>2XL</td><td>32</td><td>27</td><td>38 ½</td></tr>
          </tbody>
        </table>

      {% when 'premium-tshirt' %}
        <table class="size-chart__table">
          <thead>
            <tr>
              <th></th>
              <th>LENGTH (in)</th>
              <th>WIDTH (in)</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>S</td><td>28</td><td>18 ½</td></tr>
            <tr><td>M</td><td>29 ½</td><td>20 ½</td></tr>
            <tr><td>L</td><td>31</td><td>22 ¼</td></tr>
            <tr><td>XL</td><td>31 ¼</td><td>24</td></tr>
            <tr><td>2XL</td><td>33</td><td>25 ¼</td></tr>
            <tr><td>3XL</td><td>33 ½</td><td>26 ¾</td></tr>
          </tbody>
        </table>

    {% endcase %}
  </div>
{% endif %}

{% stylesheet %}
  .size-chart__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .size-chart__table th,
  .size-chart__table td {
    padding: 8px 12px;
    text-align: center;
    border: 1px solid var(--color-border);
  }

  .size-chart__table thead th {
    font-family: var(--font-subheading--family);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-size: 0.75rem;
    background-color: var(--color-background-2);
  }

  .size-chart__table tbody td:first-child {
    font-family: var(--font-subheading--family);
    font-weight: 600;
  }

  .size-chart__table tbody tr:nth-child(even) {
    background-color: var(--color-background-2);
  }
{% endstylesheet %}
